graph TB
    User["👤 Project Manager"]
    
    subgraph CLIENT["🖥️ CLIENT (Browser - React)"]
        UI["Web UI<br/>React + TypeScript"]
    end
    
    subgraph SERVER["⚙️ SERVER (Spring Boot 3.2.0)"]
        Controller["ProjectInputController<br/>(REST Endpoint)"]
        ProjectService["ProjectService"]
        AIEngine["AIEngine<br/>(Java Service)"]
        PromptBuilder["PromptBuilder"]
        BoardGenerator["BoardGenerator"]
        StageFactory["StageFactory"]
        TaskExtractor["TaskExtractor"]
        BoardService["BoardService"]
        CardService["CardService"]
    end
    
    subgraph CLOUD["☁️ CLOUD (External APIs)"]
        LLMProvider["OpenAI GPT-4<br/>Anthropic Claude<br/>(Remote LLM APIs)"]
    end
    
    subgraph DATABASE["🗄️ DATABASE (PostgreSQL 16.1)"]
        ProjectRepo["ProjectRepository<br/>(JPA)"]
        BoardRepo["BoardRepository<br/>(JPA)"]
        CardRepo["CardRepository<br/>(JPA)"]
        DB["PostgreSQL<br/>On-Premise/Cloud"]
    end
    
    User -->|"1. Submit Project"| UI
    UI -->|"2. HTTP POST<br/>/api/v1/projects"| Controller
