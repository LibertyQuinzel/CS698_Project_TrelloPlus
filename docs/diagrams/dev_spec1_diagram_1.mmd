    AIEngine -->|"8. Generate Structure"| BoardGenerator
    BoardGenerator -->|"9. Create Stages"| StageFactory
    StageFactory -->|"10. Extract Tasks"| TaskExtractor
    
    TaskExtractor -->|"11. Save via JPA"| ProjectRepo
    ProjectRepo -->|"12. INSERT"| DB
    TaskExtractor -->|"13. Save via JPA"| BoardRepo
    BoardRepo -->|"14. INSERT"| DB
    TaskExtractor -->|"15. Save via JPA"| CardRepo
    CardRepo -->|"16. INSERT"| DB
    
    DB -->|"17. SELECT Query"| BoardService
    BoardService -->|"18. HTTP Response"| UI
    UI -->|"19. WebSocket/REST"| User
