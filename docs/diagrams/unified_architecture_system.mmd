    classDef api fill:#9b59b6,stroke:#8e44ad,color:#fff
    classDef app fill:#e74c3c,stroke:#c0392b,color:#fff
    classDef domain fill:#f39c12,stroke:#d68910,color:#fff
    classDef data fill:#27ae60,stroke:#1e8449,color:#fff
    classDef db fill:#34495e,stroke:#2c3e50,color:#fff
    classDef external fill:#16a085,stroke:#117a65,color:#fff

    class Web client
    class WF1_REST,WF2_REST,WF3_REST,Auth_REST api
    class WF1_CTRL,WF2_CTRL,WF3_CTRL,Auth_CTRL app
    class WF1_DOMAIN,WF2_DOMAIN,WF3_DOMAIN,Shared domain
    class Data data
    class DB,Users,Projects,Boards,Cards,Stages,Meetings,Changes,ApprovalReq,ApprovalRes,ApprovalDec,AuditLog db
    class OpenAI,Anthropic external
